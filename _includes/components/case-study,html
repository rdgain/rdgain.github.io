<article class="case-study">

    <div class="case-study-image">

        <img
            src="{{ include.project.image }}"
            alt="{{ include.project.title }}"
        >

    </div>

    <div class="case-study-content">

        <span class="case-study-category">

            {{ include.project.category }}

        </span>

        <h2>

            {{ include.project.title }}

        </h2>

        <p class="case-study-summary">

            {{ include.project.summary }}

        </p>

        <div class="case-study-section">

            <h3>Problem</h3>

            <p>

                {{ include.project.problem }}

            </p>

        </div>

        <div class="case-study-section">

            <h3>Solution</h3>

            <p>

                {{ include.project.solution }}

            </p>

        </div>

        <div class="case-study-section">

            <h3>Impact</h3>

            <ul>

                {% for item in include.project.impact %}

                <li>{{ item }}</li>

                {% endfor %}

            </ul>

        </div>

        <div class="project-tags">

            {% for tech in include.project.technologies %}

            <span>

                {{ tech }}

            </span>

            {% endfor %}

        </div>

        <div class="case-study-buttons">

            {% if include.project.links.github %}

            <a
                class="btn btn-secondary"
                href="{{ include.project.links.github }}"
                target="_blank"
            >

                GitHub

            </a>

            {% endif %}

            {% if include.project.links.papers %}

            <a
                class="btn btn-secondary"
                href="{{ include.project.links.papers }}"
            >

                Publications

            </a>

            {% endif %}

            {% if include.project.links.website %}

            <a
                class="btn btn-primary"
                href="{{ include.project.links.website }}"
                target="_blank"
            >

                Website

            </a>

            {% endif %}

        </div>

    </div>

</article>